{
  "name": "@butterflylens/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12",
    "npm": ">=9"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run licenses:check && npm run media:check && tsc --noEmit && vite build",
    "check": "tsc --noEmit --pretty false",
    "licenses:check": "node scripts/dependency-licenses.mjs --check",
    "licenses:generate": "node scripts/dependency-licenses.mjs --generate",
    "media:check": "node scripts/verify-review-media.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
