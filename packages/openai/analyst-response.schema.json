{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://butterflylens.app/schemas/openai/analyst-response-v1.json",
  "title": "ButterflyLens analyst response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "response_state",
    "summary",
    "claims",
    "citations",
    "limitations",
    "tools_used",
    "model",
    "usage"
  ],
  "properties": {
    "schema_version": {
      "const": "butterflylens-analyst-response:v1.0.0"
    },
    "mode": {
      "const": "live"
    },
    "response_state": {
      "type": "string",
      "enum": ["completed", "incomplete", "refused"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "claims": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "statement", "evidence_state", "citation_ids"],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^claim_[1-9][0-9]{0,2}$"
          },
          "statement": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "evidence_state": {
            "type": "string",
            "enum": ["direct", "inference", "unavailable", "conflict"]
          },
          "citation_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 180
            }
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "repository", "commit", "path", "fingerprint"],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          },
          "repository": {
            "const": "karikris/ButterflyLens"
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "fingerprint": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 600
      }
    },
    "tools_used": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "inspect_map_scope",
          "compare_ala_and_flickr",
          "inspect_species",
          "inspect_flickr_candidate",
          "trace_record_evidence",
          "explain_classification",
          "inspect_review_consensus",
          "inspect_reviewer_quality",
          "inspect_pipeline_status",
          "inspect_worker_status",
          "recommend_next_review_batch",
          "recommend_next_species",
          "explain_geographic_contribution",
          "prepare_impact_report"
        ]
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reasoning_effort"],
      "properties": {
        "id": {
          "const": "bounded-model"
        },
        "reasoning_effort": {
          "const": "xhigh"
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_calls", "tool_calls", "budget_state"],
      "properties": {
        "response_calls": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "budget_state": {
          "type": "string",
          "enum": ["within_budget", "exhausted"]
        }
      }
    }
  }
}
