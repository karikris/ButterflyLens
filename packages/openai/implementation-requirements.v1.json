  "response_handling": {
    "statuses": ["completed", "incomplete", "failed", "cancelled"],
    "refusal_is_first_class": true,
    "incomplete_details_are_first_class": true,
    "function_call_id_preserved": true,
    "all_output_items_parsed": true,
    "budget_exhaustion_result": "bounded_incomplete",
    "tool_error_result": "bounded_incomplete",
    "live_and_replay_labels_distinct": true
  },
  "replay_policy": {
    "mode": "replayed",
    "model_invoked": false,
    "network_calls": 0,
    "response_calls": 0,
    "runtime_tool_calls": 0,
    "exact_stored_tool_calls_and_outputs": true,
    "artifact_citations_preserved": true,
    "result_trace_and_catalogue_fingerprints": "rfc8785_sha256",
    "unmatched_question_result": "unavailable_no_live_fallthrough",
    "multi_turn_simulation": false,
    "model_identity_omitted_when_not_invoked": true
  },
  "security_privacy": {
    "api_key_location": "server_environment_or_key_management_service",
    "api_key_in_browser": false,
    "api_key_in_database": false,
    "raw_secret_logging": false,
    "raw_sensitive_tool_output_logging": false,
    "openai_response_storage": false,
    "reviewer_private_fields_default": "withheld",
    "sensitive_coordinates_default": "withheld_or_governed_rollup"
  },
  "evaluation_policy": {
    "minimum_cases": 40,
    "deterministic_tool_tests_required": true,
    "stored_replay_tests_required": true,
    "live_model_evaluation_requires_key": true,
    "live_model_output_evaluated_only_when_run": true,
    "dimensions": [
