      "artifact_id",
      "repository",
      "commit",
      "path",
      "fingerprint"
    ],
    "citation_targets_allowlisted": true,
    "missing_evidence_result": "unavailable_not_zero",
    "source_conflicts_preserved": true,
    "inference_label_required": true,
    "species_guessing_from_model_memory": false,
    "scientific_claim_authority": false
