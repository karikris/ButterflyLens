{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:butterflylens:schema:common:v1.0.0",
  "title": "ButterflyLens common contract values",
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_date_time": {
      "anyOf": [
        { "$ref": "#/$defs/date_time" },
        { "type": "null" }
      ]
    },
    "nullable_stable_id": {
      "anyOf": [
        { "$ref": "#/$defs/stable_id" },
        { "type": "null" }
      ]
    },
    "nullable_probability": {
      "anyOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "null" }
      ]
    },
    "non_empty_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
