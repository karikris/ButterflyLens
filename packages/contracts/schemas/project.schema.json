{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:butterflylens:schema:project:v1.0.0",
  "title": "ButterflyLens project v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "slug",
    "name",
    "description",
    "status",
    "geographic_scope",
    "taxon_scope",
    "discovery_scope",
    "data_policy_version",
    "consent_policy_version",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "butterflylens-project:v1.0.0"
    },
    "project_id": {
      "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
    },
    "slug": {
      "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/slug"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "status": {
      "enum": ["draft", "active", "paused", "archived"]
    },
    "geographic_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "country_code",
        "boundary_id",
        "boundary_version",
        "boundary_sha256",
        "sensitive_coordinate_policy_version"
      ],
      "properties": {
        "country_code": { "const": "AU" },
        "boundary_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "boundary_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "boundary_sha256": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        },
        "sensitive_coordinate_policy_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "taxon_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_taxon_keys", "taxonomy_fingerprint"],
      "properties": {
        "root_taxon_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
          }
        },
        "taxonomy_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        }
      }
    },
    "discovery_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "search_plan_fingerprint",
        "public_discovery_claim"
      ],
      "properties": {
        "search_plan_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        },
        "public_discovery_claim": {
          "const": "All butterfly candidate images discoverable through the published ButterflyLens Flickr search plan."
        }
      }
    },
    "data_policy_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "consent_policy_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "created_at": {
      "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
    },
    "updated_at": {
      "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
    }
  }
}
