{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:butterflylens:schema:live-worker-contracts:v1.0.0",
  "title": "ButterflyLens live-worker definitions v1",
  "$defs": {
    "nullable_sha256": {
      "anyOf": [
        { "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "worker_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "worker_id",
        "registered_at",
        "machine_profile",
        "capabilities",
        "configured_models",
        "identity_fingerprint",
        "scientific_claim_allowed"
      ],
      "properties": {
        "schema_version": { "const": "butterflylens-worker-identity:v1.0.0" },
        "worker_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "registered_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "machine_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "platform",
            "architecture",
            "os_version",
            "chip_label",
            "cpu_core_count",
            "unified_memory_bytes",
            "mps_available",
            "mps_runtime"
          ],
          "properties": {
            "platform": { "enum": ["macos", "linux"] },
            "architecture": { "enum": ["arm64", "x86_64"] },
            "os_version": { "type": "string", "minLength": 1, "maxLength": 120 },
            "chip_label": { "type": "string", "minLength": 1, "maxLength": 160 },
            "cpu_core_count": { "type": "integer", "minimum": 1 },
            "unified_memory_bytes": { "type": "integer", "minimum": 1 },
            "mps_available": { "type": "boolean" },
            "mps_runtime": {
              "anyOf": [
                { "type": "string", "minLength": 1, "maxLength": 240 },
                { "type": "null" }
              ]
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supported_stage_ids",
            "max_queue_records",
            "max_queue_bytes",
            "rolling_prefetch_batches",
            "checkpoint_format",
            "graceful_shutdown_supported"
          ],
          "properties": {
            "supported_stage_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "metadata",
                  "download",
                  "media_validation",
                  "deduplication",
                  "yoloe",
                  "full_frame",
                  "bioclip",
                  "scoring",
                  "artifact_commit",
                  "cache_cleanup"
                ]
              }
            },
            "max_queue_records": { "type": "integer", "minimum": 1 },
            "max_queue_bytes": { "type": "integer", "minimum": 1 },
            "rolling_prefetch_batches": { "type": "integer", "minimum": 0, "maximum": 4 },
            "checkpoint_format": { "const": "parquet-manifest-v1" },
            "graceful_shutdown_supported": { "const": true }
          }
        },
        "configured_models": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "role",
              "model_id",
              "revision",
              "weights_sha256",
              "preprocessing_fingerprint",
              "licence_status",
              "device"
            ],
            "properties": {
              "role": { "enum": ["yoloe_router", "bioclip_embedder"] },
              "model_id": { "type": "string", "minLength": 1, "maxLength": 240 },
              "revision": { "type": "string", "minLength": 1, "maxLength": 160 },
              "weights_sha256": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
              },
              "preprocessing_fingerprint": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
              },
              "licence_status": { "enum": ["approved", "blocked"] },
              "device": { "enum": ["mps", "cpu"] }
            }
          }
        },
        "identity_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        },
        "scientific_claim_allowed": { "const": false }
      }
    },
    "model_health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "model_fingerprint",
        "status",
        "loaded_at",
        "last_check_at",
        "device",
        "message"
      ],
      "properties": {
        "role": { "enum": ["yoloe_router", "bioclip_embedder"] },
        "model_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
        "status": { "enum": ["not_configured", "not_loaded", "loading", "healthy", "degraded", "blocked"] },
        "loaded_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "last_check_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "device": {
          "anyOf": [{ "enum": ["mps", "cpu"] }, { "type": "null" }]
        },
        "message": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 500 },
            { "type": "null" }
          ]
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "heartbeat_id",
        "worker_id",
        "sequence",
        "observed_at",
        "state",
        "project_id",
        "run_id",
        "lease_id",
        "lease_revision",
        "lease_expires_at",
        "current_stage_id",
        "resources",
        "queues",
        "models",
        "cache",
        "last_committed_artifact_fingerprint",
        "last_committed_at",
        "health_checks",
        "heartbeat_fingerprint",
        "scientific_claim_allowed"
      ],
      "properties": {
        "schema_version": { "const": "butterflylens-worker-heartbeat:v1.0.0" },
        "heartbeat_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "worker_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "sequence": { "type": "integer", "minimum": 1 },
        "observed_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "state": { "enum": ["starting", "idle", "leased", "running", "paused", "draining", "degraded"] },
        "project_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "run_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "lease_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "lease_revision": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "lease_expires_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "current_stage_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "process_rss_bytes",
            "mps_allocated_bytes",
            "mps_reserved_bytes",
            "free_disk_bytes"
          ],
          "properties": {
            "process_rss_bytes": { "type": "integer", "minimum": 0 },
            "mps_allocated_bytes": {
              "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
            },
            "mps_reserved_bytes": {
              "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
            },
            "free_disk_bytes": { "type": "integer", "minimum": 0 }
          }
        },
        "queues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage_id", "record_count", "byte_count", "capacity_records", "capacity_bytes"],
            "properties": {
              "stage_id": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
              },
              "record_count": { "type": "integer", "minimum": 0 },
              "byte_count": { "type": "integer", "minimum": 0 },
              "capacity_records": { "type": "integer", "minimum": 1 },
              "capacity_bytes": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_health" }
        },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entry_count", "byte_count", "hit_count", "miss_count"],
          "properties": {
            "entry_count": { "type": "integer", "minimum": 0 },
            "byte_count": { "type": "integer", "minimum": 0 },
            "hit_count": { "type": "integer", "minimum": 0 },
            "miss_count": { "type": "integer", "minimum": 0 }
          }
        },
        "last_committed_artifact_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
        "last_committed_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "health_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["check_id", "status", "message"],
            "properties": {
              "check_id": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
              },
              "status": { "enum": ["pass", "warn", "fail", "unavailable"] },
              "message": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          }
        },
        "heartbeat_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        },
        "scientific_claim_allowed": { "const": false }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "lease_id",
        "project_id",
        "run_id",
        "stage_id",
        "worker_id",
        "status",
        "revision",
        "fencing_token",
        "idempotency_key",
        "issued_at",
        "acquired_at",
        "renewed_at",
        "expires_at",
        "released_at",
        "checkpoint_fingerprint",
        "cancellation_requested",
        "cancellation_requested_at",
        "lease_fingerprint"
      ],
      "properties": {
        "schema_version": { "const": "butterflylens-worker-lease:v1.0.0" },
        "lease_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "project_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "run_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "stage_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "worker_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "status": { "enum": ["offered", "active", "released", "expired", "revoked"] },
        "revision": { "type": "integer", "minimum": 1 },
        "fencing_token": { "type": "string", "pattern": "^[0-9]+$", "maxLength": 40 },
        "idempotency_key": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "issued_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "acquired_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "renewed_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "expires_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "released_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "checkpoint_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
        "cancellation_requested": { "type": "boolean" },
        "cancellation_requested_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_date_time"
        },
        "lease_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "active" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "acquired_at": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
              },
              "released_at": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "cancellation_requested": { "const": true } },
            "required": ["cancellation_requested"]
          },
          "then": {
            "properties": {
              "cancellation_requested_at": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
              }
            }
          }
        }
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command_id",
        "worker_id",
        "project_id",
        "run_id",
        "lease_id",
        "expected_lease_revision",
        "kind",
        "idempotency_key",
        "issued_at",
        "expires_at",
        "requested_by",
        "payload",
        "command_fingerprint"
      ],
      "properties": {
        "schema_version": { "const": "butterflylens-worker-command:v1.0.0" },
        "command_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "worker_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "project_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "run_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "lease_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
        },
        "expected_lease_revision": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "kind": { "enum": ["start_run", "pause_run", "resume_run", "cancel_run", "health_check", "graceful_shutdown"] },
        "idempotency_key": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "issued_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "expires_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "requested_by": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stage_id", "checkpoint_fingerprint", "reason"],
          "properties": {
            "stage_id": {
              "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/nullable_stable_id"
            },
            "checkpoint_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
            "reason": {
              "anyOf": [
                { "type": "string", "minLength": 1, "maxLength": 500 },
                { "type": "null" }
              ]
            }
          }
        },
        "command_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "worker_id",
        "sequence",
        "project_id",
        "run_id",
        "lease_id",
        "lease_revision",
        "kind",
        "stage_id",
        "occurred_at",
        "records_processed",
        "bytes_processed",
        "checkpoint_fingerprint",
        "artifact_fingerprint",
        "error",
        "event_fingerprint",
        "scientific_claim_allowed"
      ],
      "properties": {
        "schema_version": { "const": "butterflylens-worker-event:v1.0.0" },
        "event_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "worker_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "sequence": { "type": "integer", "minimum": 1 },
        "project_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "run_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "lease_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "lease_revision": { "type": "integer", "minimum": 1 },
        "kind": {
          "enum": [
            "stage_started",
            "progress",
            "checkpoint_committed",
            "artifact_committed",
            "stage_succeeded",
            "stage_failed",
            "run_paused",
            "run_cancelled",
            "shutdown_started",
            "shutdown_complete"
          ]
        },
        "stage_id": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/stable_id"
        },
        "occurred_at": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/date_time"
        },
        "records_processed": { "type": "integer", "minimum": 0 },
        "bytes_processed": { "type": "integer", "minimum": 0 },
        "checkpoint_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
        "artifact_fingerprint": { "$ref": "#/$defs/nullable_sha256" },
        "error": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message", "retryable"],
              "properties": {
                "code": { "type": "string", "minLength": 1, "maxLength": 120 },
                "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                "retryable": { "type": "boolean" }
              }
            }
          ]
        },
        "event_fingerprint": {
          "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
        },
        "scientific_claim_allowed": { "const": false }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "artifact_committed" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "artifact_fingerprint": {
                "$ref": "urn:butterflylens:schema:common:v1.0.0#/$defs/sha256"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "stage_failed" } },
            "required": ["kind"]
          },
          "then": { "properties": { "error": { "type": "object" } } }
        }
      ]
    }
  }
}
