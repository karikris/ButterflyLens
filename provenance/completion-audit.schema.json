{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karikris.github.io/ButterflyLens/schemas/completion-audit-v1.json",
  "title": "ButterflyLens completion audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "generated_at",
    "repository",
    "branch",
    "audited_commit",
    "audited_tree",
    "source_goal_sha256",
    "primary_session_id",
    "requested_model",
    "requested_reasoning_effort",
    "goal_complete",
    "completion_rule",
    "status_definitions",
    "criteria_summary",
    "artifact_summary",
    "authoritative_boundaries",
    "criteria",
    "minimum_artifacts"
  ],
  "properties": {
    "schema_version": {"const": "butterflylens-completion-audit/v1.0.0"},
    "audit_id": {"type": "string", "pattern": "^butterflylens-[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "repository": {"const": "karikris/ButterflyLens"},
    "branch": {"const": "main"},
    "audited_commit": {"$ref": "#/$defs/git_sha"},
    "audited_tree": {"$ref": "#/$defs/git_sha"},
    "source_goal_sha256": {"$ref": "#/$defs/sha256"},
    "primary_session_id": {"type": "string", "format": "uuid"},
    "requested_model": {"const": "gpt-5.6-sol"},
    "requested_reasoning_effort": {"const": "xhigh"},
    "goal_complete": {"type": "boolean"},
    "completion_rule": {"type": "string", "minLength": 1},
    "status_definitions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["satisfied", "partial", "blocked_by_user_instruction", "blocked_external"],
      "properties": {
        "satisfied": {"type": "string", "minLength": 1},
        "partial": {"type": "string", "minLength": 1},
        "blocked_by_user_instruction": {"type": "string", "minLength": 1},
        "blocked_external": {"type": "string", "minLength": 1}
      }
    },
    "criteria_summary": {"$ref": "#/$defs/summary"},
    "artifact_summary": {"$ref": "#/$defs/artifact_summary"},
    "authoritative_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ala", "gbif", "biominer", "flickr", "models"],
      "properties": {
        "ala": {"type": "string", "minLength": 1},
        "gbif": {"type": "string", "minLength": 1},
        "biominer": {"type": "string", "minLength": 1},
        "flickr": {"type": "string", "minLength": 1},
        "models": {"type": "string", "minLength": 1}
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 100,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/criterion"}
    },
    "minimum_artifacts": {
      "type": "array",
      "minItems": 46,
      "maxItems": 46,
      "items": {"$ref": "#/$defs/artifact"}
    }
  },
  "$defs": {
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "criterion_status": {
      "enum": ["satisfied", "partial", "blocked_by_user_instruction", "blocked_external"]
    },
    "artifact_status": {
      "enum": ["present", "present_equivalent", "blocked_by_user_instruction", "blocked_external"]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "satisfied", "partial", "blocked_by_user_instruction", "blocked_external"],
      "properties": {
        "total": {"const": 100},
        "satisfied": {"type": "integer", "minimum": 0},
        "partial": {"type": "integer", "minimum": 0},
        "blocked_by_user_instruction": {"type": "integer", "minimum": 0},
        "blocked_external": {"type": "integer", "minimum": 0}
      }
    },
    "artifact_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "present", "present_equivalent", "blocked_by_user_instruction", "blocked_external"],
      "properties": {
        "total": {"const": 46},
        "present": {"type": "integer", "minimum": 0},
        "present_equivalent": {"type": "integer", "minimum": 0},
        "blocked_by_user_instruction": {"type": "integer", "minimum": 0},
        "blocked_external": {"type": "integer", "minimum": 0}
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "criterion", "status", "evidence", "rationale", "next_action"],
      "properties": {
        "id": {"type": "integer", "minimum": 1, "maximum": 100},
        "category": {"type": "string", "minLength": 1},
        "criterion": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/criterion_status"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/path"}
        },
        "rationale": {"type": "string", "minLength": 1},
        "next_action": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "required", "status", "evidence", "note"],
      "properties": {
        "category": {"type": "string", "minLength": 1},
        "required": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/artifact_status"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/path"}
        },
        "note": {"type": "string", "minLength": 1}
      }
    }
  }
}
